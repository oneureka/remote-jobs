---
import '@assets/globals.css'

export interface Props {
  title?: string
  description?: string
}

const {
  title = 'Remote Jobs',
  description = 'Curated remote-friendly companies and job opportunities from around the world'
} = Astro.props
const path = Astro.url.pathname
const siteUrl = `https://remote-jobs.example.com${path}`
const isActive = (p: string) => path === p || (p !== '/' && path.startsWith(p))
---

<!doctype html>
<html lang="en" data-theme="bumblebee">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta name="twitter:card" content="summary" />
    <link rel="canonical" href={siteUrl} />
    <style is:global>
      body {
        background-image:
          linear-gradient(
            -90deg,
            color-mix(in srgb, currentColor 2%, transparent) 1px,
            transparent 1px
          ),
          linear-gradient(
            color-mix(in srgb, currentColor 2%, transparent) 1px,
            transparent 1px
          ),
          linear-gradient(
            -90deg,
            color-mix(in srgb, currentColor 2%, transparent) 1px,
            transparent 1px
          ),
          linear-gradient(
            color-mix(in srgb, currentColor 2%, transparent) 1px,
            transparent 1px
          );
        background-size:
          6px 6px,
          6px 6px,
          120px 120px,
          120px 120px;
      }
    </style>
  </head>
  <body class="antialiased leading-none text-base-content bg-base-200 pt-14">
    <nav
      id="navbar"
      class="fixed top-0 left-0 right-0 z-50 h-14 transition-[background,border-color,box-shadow] duration-300 border-b border-transparent"
    >
      <div
        class="mx-auto max-w-2xl px-5 h-full flex items-center justify-between"
      >
        <a
          href="/"
          class="flex items-baseline gap-0.5 text-sm font-semibold tracking-tight"
        >
          <span class="text-primary">re:</span>
          <span class="text-base-content">set</span>
        </a>
        <div class="flex items-center gap-1.5">
          <a
            href="/companies"
            class="px-3 py-1.5 text-sm rounded-md transition-colors"
            class:list={{
              'text-base-content font-medium bg-base-content/10':
                isActive('/companies'),
              'text-base-content/60 hover:text-base-content hover:bg-base-content/[0.06]':
                !isActive('/companies')
            }}
          >
            公司
          </a>
          <a
            href="/livable"
            class="px-3 py-1.5 text-sm rounded-md transition-colors"
            class:list={{
              'text-base-content font-medium bg-base-content/10':
                isActive('/livable'),
              'text-base-content/60 hover:text-base-content hover:bg-base-content/[0.06]':
                !isActive('/livable')
            }}
          >
            城市
          </a>
        </div>
      </div>
    </nav>
    <slot />
    <footer
      class="mx-auto max-w-2xl px-5 py-8 text-center md:text-left text-xs text-base-content/50"
    >
      <p class="m-0">
        <a
          href="/"
          class="text-inherit underline underline-offset-2 hover:text-base-content/70"
          >Remote Jobs</a
        >
        &nbsp;—&nbsp;curated remote-friendly companies
      </p>
      <p class="m-0 mt-2">
        Built with&nbsp;<a
          href="https://astro.build"
          class="text-inherit underline underline-offset-2 hover:text-base-content/70"
          target="_blank">Astro</a
        >
        &nbsp;·&nbsp;
        <a
          href="/jobs"
          class="text-inherit underline underline-offset-2 hover:text-base-content/70"
          >Search Jobs</a
        >
        &nbsp;·&nbsp;
        <a
          href="/companies"
          class="text-inherit underline underline-offset-2 hover:text-base-content/70"
          >Companies</a
        >
        &nbsp;·&nbsp;
        <a
          href="/livable"
          class="text-inherit underline underline-offset-2 hover:text-base-content/70"
          >Livable Cities</a
        >
      </p>
    </footer>
    <style is:global>
      #navbar {
        background: transparent;
        box-shadow: none;
      }
      #navbar.scrolled {
        background: linear-gradient(
          to bottom,
          transparent 0%,
          color-mix(in srgb, var(--color-base-100) 92%, transparent) 100%
        );
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom-color: var(--color-base-300);
        box-shadow: 0 1px 3px
          color-mix(in srgb, var(--color-base-content) 6%, transparent);
      }
    </style>
    <script>
      const n = document.getElementById('navbar')
      const update = () => n.classList.toggle('scrolled', window.scrollY > 0)
      window.addEventListener('scroll', update, { passive: true })
      update()
    </script>
  </body>
</html>
