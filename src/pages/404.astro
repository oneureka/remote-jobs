---
import Layout from '@layouts/layout.astro'
---

<Layout>
  <div class="mx-auto max-w-2xl px-5 pt-7.5">
    <h2 class="text-2xl leading-9">404 — Page Not Found</h2>
    <p class="mt-1 text-sm text-gray-400">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a href="/" class="mt-6 inline-block text-sm text-gray-500 underline underline-offset-2 hover:text-gray-700">
      Back to Home
    </a>
  </div>
</Layout>
