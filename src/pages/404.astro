---
import Layout from '@layouts/layout.astro'
---

<Layout
  title="404 — Remote Jobs"
  description="The page you're looking for doesn't exist or has been moved."
>
  <div class="mx-auto max-w-2xl px-5 pt-7.5">
    <h2 class="text-2xl leading-9">404 — Page Not Found</h2>
    <p class="mt-1 text-sm text-base-content/50">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="mt-6 inline-block text-sm text-base-content/70 underline underline-offset-2 hover:text-base-content"
    >
      Back to Home
    </a>
  </div>
</Layout>
