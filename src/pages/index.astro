---
import Layout from '../layouts/Layout.astro'
import RegionSection from '../components/RegionSection.astro'
import { getCollection } from 'astro:content'
import { groupByRegion } from '../utils/groupByRegion'

const companies = await getCollection('companies')

const groups = groupByRegion(companies, (c) => c.data.region)
---

<Layout>
  <div class="mx-auto max-w-[1200px] px-5">
    <header class="pt-[30px]">
      <div class="mb-5">
        <h2 class="text-2xl leading-9">Hey 👋</h2>
        <h3 class="text-slate-500 text-2xl leading-8 font-medium">
          Remote Jobs
        </h3>
      </div>
    </header>

    {
      groups.map(({ region, items }) => (
        <RegionSection region={region} count={items.length} countLabel="companies">
          {
            items.map((company) => (
              <a
                href={company.id}
                class="card border border-slate-200 rounded-xl p-4 transition-all duration-200 hover:border-blue-400 hover:shadow-sm bg-white"
              >
                <div class="flex items-center gap-2.5 mb-2">
                  <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-100 to-blue-200 flex items-center justify-center text-sm font-bold text-blue-600 shrink-0">
                    {company.data.companyName[0]}
                  </div>
                  <div class="min-w-0">
                    <h4 class="text-sm font-semibold text-gray-900 truncate m-0">{company.data.companyName}</h4>
                    <p class="text-xs text-slate-400 truncate">{company.data.industry[0]}</p>
                  </div>
                </div>
                <div class="flex flex-wrap gap-x-2 gap-y-1 text-xs text-slate-500 mt-1">
                  {
                    company.data.remotePolicy.map((p: string) => (
                      <span class="text-blue-600 font-medium">{p}</span>
                    ))
                  }
                </div>
              </a>
            ))
          }
        </RegionSection>
      ))
    }
  </div>
</Layout>
