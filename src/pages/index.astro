---
import Layout from '@layouts/layout.astro'
import JobCard from '@components/job-card.astro'
import jobs from '../data.json'
---

<Layout title="Remote Jobs" description="Curated remote-friendly companies and job opportunities from around the world">
  <div class="mx-auto max-w-2xl px-5">
    <header class="pt-7.5">
      <div class="mb-2">
        <h2 class="text-2xl leading-9">Remote Jobs</h2>
        <p class="text-sm text-base-content/50 mt-1">
          Curated remote-friendly companies and job opportunities
        </p>
      </div>
    </header>

    <div id="job-list" class="my-6">
      {
        jobs.map((job, i) => (
          <JobCard job={job} index={i} />
        ))
      }
    </div>

    <div class="flex justify-center pb-14">
      <button id="load-more" class="btn btn-neutral">
        Load more
      </button>
    </div>
  </div>
</Layout>

<style is:global>
</style>

<script>
  document.getElementById('load-more')?.addEventListener('click', () => {})
</script>
