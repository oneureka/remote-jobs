---
import Layout from '@layouts/layout.astro'
import RegionSection from '../../components/region-section.astro'
import CityCard from '../../components/city-card.astro'
import { getCollection } from 'astro:content'
import { groupByRegion } from '../../utils/groupByRegion'
import { loadCities, slugify } from '../../utils/citiesData'

const { chinaCities } = loadCities()
const globalCities = await getCollection('cities')
const globalGroups = groupByRegion(globalCities, (c) => c.data.Region)
const chinaGroups = groupByRegion(chinaCities, (c) => c.Region)
---

<Layout
  title="Livable Cities — Remote Jobs"
  description="Discover cities for digital nomads"
>
  <div class="mx-auto max-w-2xl px-5">
    <header class="pt-7.5">
      <div class="mb-2">
        <h2 class="text-2xl leading-9">Livable Cities</h2>
        <p class="text-sm text-base-content/50 mt-1">
          Discover cities for digital nomads
        </p>
      </div>
    </header>

    <div class="flex gap-2 mb-6" id="city-tabs">
      <button class="btn btn-soft btn-active" data-tab="global" id="tab-global">
        全球
      </button>
      <button class="btn btn-soft" data-tab="china" id="tab-china">
        中国内地
      </button>
    </div>

    <div id="city-list-global">
      {
        globalGroups.map(({ region, items }) => (
          <RegionSection
            region={region}
            count={items.length}
            countLabel="cities"
          >
            {items.map((city) => (
              <CityCard
                name={city.data.City}
                location={city.data.Country}
                href={`/livable/${slugify(city.data.City)}`}
                avgAqi={Number(city.data['Avg AQI'])}
                tempRange={city.data['Temp Range']}
                costTier={city.data['Cost Tier']}
              />
            ))}
          </RegionSection>
        ))
      }
    </div>

    <div id="city-list-china" class="hidden">
      {
        chinaGroups.map(({ region, items }) => (
          <RegionSection
            region={region}
            count={items.length}
            countLabel="cities"
          >
            {items.map((city) => (
              <CityCard
                name={city.City}
                location={city.Province}
                href={`/livable/${slugify(city.City)}`}
                avgAqi={Number(city['Avg AQI'])}
                tempRange={city['Temp Range']}
                costTier={city['Cost Tier']}
              />
            ))}
          </RegionSection>
        ))
      }
    </div>
  </div>
</Layout>

<script>
  document.getElementById('city-tabs')?.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-tab]')
    if (!btn) return

    const tab = btn.getAttribute('data-tab')
    const isGlobal = tab === 'global'

    document
      .getElementById('city-list-global')
      .classList.toggle('hidden', !isGlobal)
    document
      .getElementById('city-list-china')
      .classList.toggle('hidden', isGlobal)
    document
      .getElementById('tab-global')
      .classList.toggle('btn-active', isGlobal)
    document
      .getElementById('tab-china')
      .classList.toggle('btn-active', !isGlobal)
  })
</script>
