---
import Layout from '@layouts/layout.astro'
import RegionSection from '../../components/region-section.astro'
import { getCollection } from 'astro:content'
import { groupByRegion } from '../../utils/groupByRegion'
import { loadCities, slugify } from '../../utils/citiesData'

const { chinaCities } = loadCities()
const globalCities = await getCollection('cities')
const globalGroups = groupByRegion(globalCities, (c) => c.data.Region)
const chinaGroups = groupByRegion(chinaCities, (c) => c.Region)
---

<Layout
  title="Livable Cities — Remote Jobs"
  description="Discover cities for digital nomads"
>
  <div class="mx-auto max-w-2xl px-5">
    <header class="pt-7.5">
      <div class="mb-2">
        <h2 class="text-2xl leading-9">Livable Cities</h2>
        <p class="text-sm text-base-content/50 mt-1">
          Discover cities for digital nomads
        </p>
      </div>
    </header>

    <div class="flex gap-2 mb-6" id="city-tabs">
      <button
        class="btn btn-soft btn-active rounded-full"
        data-tab="global"
        id="tab-global"
      >
        全球
      </button>
      <button
        class="btn btn-primary rounded-full"
        data-tab="china"
        id="tab-china"
      >
        中国内地
      </button>
    </div>

    <div id="city-list-global">
      {
        globalGroups.map(({ region, items }) => (
          <RegionSection
            region={region}
            count={items.length}
            countLabel="cities"
          >
            {items.map((city) => (
              <a
                href={`/livable/${slugify(city.data.City)}`}
                class="card border border-base-300 rounded-xl p-4 transition-all duration-200 hover:border-primary hover:shadow-sm bg-base-100"
              >
                <div class="flex items-center gap-2.5 mb-2">
                  <div class="w-8 h-8 mask mask-squircle bg-linear-to-br from-primary/10 to-primary/20 flex items-center justify-center text-sm font-bold text-primary shrink-0">
                    {city.data.City[0]}
                  </div>
                  <div class="min-w-0">
                    <h4 class="text-sm font-semibold text-base-content truncate m-0">
                      {city.data.City}
                    </h4>
                    <p class="text-xs text-base-content/50 truncate">
                      {city.data.Country}
                    </p>
                  </div>
                </div>
                <div class="flex flex-wrap gap-x-2 gap-y-1 text-xs text-base-content/70 mt-1">
                  <span class="inline-flex items-center gap-1">
                    <span
                      class="w-1.5 h-1.5 rounded-full"
                      class:list={[
                        city.data['Avg AQI'] <= 50
                          ? 'bg-success'
                          : city.data['Avg AQI'] <= 100
                            ? 'bg-warning'
                            : 'bg-error'
                      ]}
                    />
                    AQI {city.data['Avg AQI']}
                  </span>
                  <span>{city.data['Temp Range']}</span>
                  <span
                    class="font-medium"
                    class:list={[
                      city.data['Cost Tier'] === 'Low'
                        ? 'text-success'
                        : city.data['Cost Tier'] === 'Mid'
                          ? 'text-warning'
                          : 'text-error'
                    ]}
                  >
                    {city.data['Cost Tier']}
                  </span>
                </div>
              </a>
            ))}
          </RegionSection>
        ))
      }
    </div>

    <div id="city-list-china" class="hidden">
      {
        chinaGroups.map(({ region, items }) => (
          <RegionSection
            region={region}
            count={items.length}
            countLabel="cities"
          >
            {items.map((city) => (
              <a
                href={`/livable/${slugify(city.City)}`}
                class="card border border-base-300 rounded-xl p-4 transition-all duration-200 hover:border-primary hover:shadow-sm bg-base-100"
              >
                <div class="flex items-center gap-2.5 mb-2">
                  <div class="w-8 h-8 rounded-full bg-linear-to-br from-primary/10 to-primary/20 flex items-center justify-center text-sm font-bold text-primary shrink-0">
                    {city.City[0]}
                  </div>
                  <div class="min-w-0">
                    <h4 class="text-sm font-semibold text-base-content truncate m-0">
                      {city.City}
                    </h4>
                    <p class="text-xs text-base-content/50 truncate">
                      {city.Province}
                    </p>
                  </div>
                </div>
                <div class="flex flex-wrap gap-x-2 gap-y-1 text-xs text-base-content/70 mt-1">
                  <span class="inline-flex items-center gap-1">
                    <span
                      class="w-1.5 h-1.5 rounded-full"
                      class:list={[
                        city['Avg AQI'] <= 50
                          ? 'bg-success'
                          : city['Avg AQI'] <= 100
                            ? 'bg-warning'
                            : 'bg-error'
                      ]}
                    />
                    AQI {city['Avg AQI']}
                  </span>
                  <span>{city['Temp Range']}</span>
                  <span
                    class="font-medium"
                    class:list={[
                      city['Cost Tier'] === 'Low'
                        ? 'text-success'
                        : city['Cost Tier'] === 'Mid'
                          ? 'text-warning'
                          : 'text-error'
                    ]}
                  >
                    {city['Cost Tier']}
                  </span>
                </div>
              </a>
            ))}
          </RegionSection>
        ))
      }
    </div>
  </div>
</Layout>

<script>
  document.getElementById('city-tabs')?.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-tab]')
    if (!btn) return

    const tab = btn.getAttribute('data-tab')
    const isGlobal = tab === 'global'

    document
      .getElementById('city-list-global')
      .classList.toggle('hidden', !isGlobal)
    document
      .getElementById('city-list-china')
      .classList.toggle('hidden', isGlobal)
    document
      .getElementById('tab-global')
      .classList.toggle('btn-active', isGlobal)
    document
      .getElementById('tab-china')
      .classList.toggle('btn-active', !isGlobal)
  })
</script>
