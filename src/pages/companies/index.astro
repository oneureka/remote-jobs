---
import Layout from '@layouts/layout.astro'
import RegionSection from '../../components/region-section.astro'
import { getCollection } from 'astro:content'
import { groupByRegion } from '../../utils/groupByRegion'

const companies = await getCollection('companies')
const allRegions = [...new Set(companies.map((c) => c.data.region))]
const groups = groupByRegion(companies, (c) => c.data.region)
---

<Layout
  title="Companies — Remote Jobs"
  description="Remote-friendly companies by region"
>
  <div class="mx-auto max-w-2xl px-5">
    <header class="pt-7.5">
      <div class="mb-2">
        <h2 class="text-2xl leading-9">Companies</h2>
        <p class="text-sm text-base-content/50 mt-1">
          Remote-friendly companies by region
        </p>
      </div>
    </header>

    <div class="flex flex-wrap gap-2 mb-6" id="region-filters">
      <button class="btn btn-soft btn-active" data-region="all" id="filter-all">
        All ({companies.length})
      </button>
      {
        allRegions.map((region) => (
          <button class="btn btn-soft" data-region={region}>
            {region} ({companies.filter((c) => c.data.region === region).length}
            )
          </button>
        ))
      }
    </div>

    {
      groups.map(({ region, items }) => (
        <div class="region-section" data-region={region}>
          <RegionSection
            region={region}
            count={items.length}
            countLabel="companies"
          >
            {items.map((company) => (
              <a
                href={`/companies/${company.id}`}
                class="card border border-base-300 rounded-xl p-4 transition-all duration-200 hover:border-primary hover:shadow-sm bg-base-100"
              >
                <div class="flex items-center gap-2.5 mb-2">
                  <div class="w-8 h-8 rounded-full bg-linear-to-br from-primary/10 to-primary/20 flex items-center justify-center text-sm font-bold text-primary shrink-0">
                    {company.data.companyName[0]}
                  </div>
                  <div class="min-w-0">
                    <h4 class="text-sm font-semibold text-base-content truncate m-0">
                      {company.data.companyName}
                    </h4>
                    <p class="text-xs text-base-content/50 truncate">
                      {company.data.industry[0]}
                    </p>
                  </div>
                </div>
                <div class="flex flex-wrap gap-x-2 gap-y-1 text-xs text-base-content/70 mt-1">
                  {company.data.remotePolicy.map((p: string) => (
                    <span class="text-primary font-medium">{p}</span>
                  ))}
                </div>
              </a>
            ))}
          </RegionSection>
        </div>
      ))
    }
  </div>
</Layout>

<script>
  document.getElementById('region-filters')?.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-region]')
    if (!btn) return

    const region = btn.getAttribute('data-region')

    document.querySelectorAll('.region-section').forEach((el) => {
      el.style.display =
        region === 'all' || el.getAttribute('data-region') === region
          ? ''
          : 'none'
    })
    document.querySelectorAll('#region-filters .btn').forEach((b) => {
      const isActive =
        b.getAttribute('data-region') === region ||
        (region === 'all' && b.getAttribute('data-region') === 'all')
      b.classList.toggle('btn-active', isActive)
    })
  })
</script>
