---
import Layout from '@layouts/layout.astro'
import { getCollection, getEntry, render } from 'astro:content'

export async function getStaticPaths() {
  const companies = await getCollection('companies')
  return companies.map((c) => ({
    params: { id: c.id }
  }))
}

const { id } = Astro.params
const company = await getEntry('companies', id!)
const { Content } = await render(company)
---

<Layout title={`${company.data.companyName} — Remote Jobs`} description={`${company.data.companyName} — ${company.data.region}. ${company.data.industry.join(', ')}`}>
  <div class="mx-auto max-w-2xl px-5">
    <header class="pt-7.5">
      <a href="/companies" class="text-xs text-base-content/50 hover:text-base-content/70"
        >&larr; Companies</a
      >
    </header>

    <div class="mt-4 mb-8">
      <div class="flex items-center gap-3 mb-3">
        <div
          class="w-10 h-10 rounded-full bg-linear-to-br from-primary/10 to-primary/20 flex items-center justify-center text-lg font-bold text-primary shrink-0"
        >
          {company.data.companyName[0]}
        </div>
        <div>
          <h1 class="text-2xl font-semibold text-base-content m-0">
            {company.data.companyName}
          </h1>
          <p class="text-sm text-base-content/50 m-0">{company.data.region}</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-2 text-xs mb-3">
        {
          company.data.industry.map((ind: string) => (
            <span class="bg-base-200 border border-base-300 px-2.5 py-1 rounded-md">
              {ind}
            </span>
          ))
        }
        {
          company.data.remotePolicy.map((p: string) => (
            <span class="text-primary font-medium bg-base-200 border border-base-300 px-2.5 py-1 rounded-md">
              {p}
            </span>
          ))
        }
      </div>

      {
        company.data.website && (
          <a
            href={company.data.website}
            target="_blank"
            class="inline-flex items-center gap-1 text-xs text-base-content/70 hover:text-base-content bg-base-200 border border-base-300 px-2.5 py-1 rounded-md"
          >
            {company.data.website.replace(/^https?:\/\//, '')}
          </a>
        )
      }
    </div>

    <div
      class="border border-base-300 rounded-xl p-5 bg-base-100 mb-8 text-sm text-base-content/80 leading-relaxed"
    >
      <Content />
    </div>
  </div>
</Layout>
