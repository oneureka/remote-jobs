---
import Layout from '@layouts/layout.astro'
import JobCard from '@components/job-card.astro'
import jobs from '../../data.json'
---

<Layout>
  <div class="mx-auto max-w-2xl px-5">
    <header class="pt-7.5">
      <div class="mb-2">
        <h2 class="text-2xl leading-9">Search Jobs</h2>
        <p class="text-sm text-base-content/50 mt-1">
          Find remote jobs by company, role, or keyword
        </p>
      </div>
    </header>

    <div class="mb-6">
      <input
        id="search-input"
        type="text"
        placeholder="Search jobs..."
        class="w-full border border-base-300 rounded-lg px-4 py-2.5 text-sm text-base-content bg-base-100 focus:outline-none focus:border-primary transition-colors"
        oninput="filterJobs(this.value)"
      />
    </div>

    <div class="mb-2">
      <span id="result-count" class="text-xs text-base-content/50"
        >{jobs.length} results</span
      >
    </div>

    <div id="job-list" class="mb-14">
      {
        jobs.map((job, i) => (
          <JobCard
            job={job}
            extraAttrs={{
              class: 'job-card',
              'data-company': job.company.toLowerCase(),
              'data-position': job.position.toLowerCase(),
              'data-location': job.location.toLowerCase(),
              'data-tags': job.tags.join(' ').toLowerCase()
            }}
          />
        ))
      }
    </div>
  </div>
</Layout>

<script>
  function filterJobs(query) {
    const q = query.toLowerCase().trim()
    const cards = document.querySelectorAll('.job-card')
    let count = 0

    cards.forEach((card) => {
      const company = card.getAttribute('data-company')
      const position = card.getAttribute('data-position')
      const location = card.getAttribute('data-location')
      const tags = card.getAttribute('data-tags')

      const match =
        !q ||
        company.includes(q) ||
        position.includes(q) ||
        location.includes(q) ||
        tags.includes(q)

      card.style.display = match ? '' : 'none'
      if (match) count++
    })

    document.getElementById('result-count').textContent = count + ' results'
  }
</script>
