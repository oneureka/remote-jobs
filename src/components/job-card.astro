---
interface Job {
  company: string
  position: string
  location: string
  salary: string
  tags: string[]
  posted: string
  url: string
}

interface Props {
  job: Job
  index?: number
  extraAttrs?: Record<string, string>
}

const { job, index, extraAttrs } = Astro.props
const dataAttrs: Record<string, string> = { ...extraAttrs }
delete dataAttrs.class
if (index !== undefined) dataAttrs['data-index'] = String(index)
---

<a
  href={job.url}
  target="_blank"
  class:list={[
    'group flex gap-4 w-full px-4 py-4 mb-3 border border-base-300 border-l-4 border-l-neutral/90 bg-base-100 rounded-l transition-all duration-200',
    extraAttrs?.class
  ]}
  {...dataAttrs}
>
  <img
    src={`https://placehold.co/70x70/f3f4f6/9ca3af?text=+`}
    alt={`${job.company} logo`}
    class="w-[70px] h-[70px] mask mask-squircle bg-base-200 shrink-0"
    loading="lazy"
  />

  <div class="flex flex-col min-w-0 flex-1 gap-2">
    <div class="flex items-center justify-between">
      <h3 class="text-lg font-semibold text-base-content truncate m-0">
        {job.company}
      </h3>
      <p class="text-xs text-base-content/50 shrink-0 ml-2">
        {job.posted}
      </p>
    </div>

    <div class="md:flex md:items-center md:justify-between">
      <p class="text-sm text-base-content/70 m-0">{job.position}</p>
      <div class="flex flex-wrap items-center gap-1.5 mt-1 md:mt-0">
        <span
          class="text-xs text-base-content/60 bg-base-200 border border-base-300 px-2 py-0.5 rounded-md leading-none"
        >
          {job.location}
        </span>
        <span
          class="text-xs text-success font-semibold bg-success/10 border border-success/20 px-2 py-0.5 rounded-md leading-none"
        >
          {job.salary}
        </span>
        {
          job.tags.map((tag) => (
            <span class="text-xs text-base-content/50 bg-base-200 px-2 py-0.5 rounded-md leading-none">
              {tag}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</a>
